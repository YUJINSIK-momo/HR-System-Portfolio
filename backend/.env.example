# Backend Environment Variables — Copy to .env and fill in your values

# Database (Supabase / PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"
# Prisma tips:
# - P1002 advisory lock timeout → set PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 during migrate
# - Use Direct connection URI (not Transaction pooler) for `prisma migrate deploy`

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
FRONTEND_URL="http://localhost:5174"

# Public Holidays API (data.go.kr) — for Korean holiday sync feature
# Sign up at https://www.data.go.kr/ and request "특일정보" API key
DATA_GO_KR_SERVICE_KEY=""

# Google Gemini AI — required for GEMINI chat page
GEMINI_API_KEY=""
# Optional overrides:
# GEMINI_CHAT_MODEL="gemini-1.5-flash"
# GEMINI_IMAGE_MODEL="gemini-1.5-flash"
# GEMINI_CHAT_SYSTEM="You are a helpful HR assistant..."

# AWS S3 — for file/image uploads (optional for portfolio demo)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
S3_CHAT_BUCKET=""
S3_IMG_BUCKET=""
# S3 CORS config: aws s3api put-bucket-cors --bucket BUCKET --cors-configuration file://s3-cors-config.json
